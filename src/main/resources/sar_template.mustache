<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Subject Access Request – Commissioned Rehabilitation Services</title>
  <style>
    body { font-family: Arial, sans-serif; font-size: 13px; color: #222; }
    h1 { font-size: 1.4em; border-bottom: 2px solid #333; padding-bottom: 4px; }
    h2 { font-size: 1.2em; border-bottom: 1px solid #999; margin-top: 24px; }
    h3 { font-size: 1.05em; margin-top: 16px; color: #333; }
    h4 { font-size: 1em; margin-top: 12px; color: #555; }
    table { border-collapse: collapse; width: 100%; margin-bottom: 12px; }
    th, td { border: 1px solid #ccc; padding: 4px 8px; text-align: left; vertical-align: top; }
    th { font-weight: bold; width: 35%; }
    .section { margin-bottom: 24px; }
    .no-data { color: #888; font-style: italic; }
  </style>
</head>
<body>

<h1>Commissioned Rehabilitation Services (CRS)</h1>

{{#referral}}
<div class="section">
  <h2>Referral: {{ optionalString referral_number }}</h2>

  <h3>Referral Summary</h3>
  <table>
    <tr><th>Referral Number</th><td>{{ optionalString referral_number }}</td></tr>
    <tr><th>Status</th><td>{{ optionalString status }}</td></tr>
    <tr><th>Service User CRN</th><td>{{ optionalString service_user_crn }}</td></tr>
    <tr><th>Service Provider</th><td>{{ optionalString service_provider_name }}</td></tr>
    <tr><th>Created At</th><td>{{ formatDate created_at }}</td></tr>
    <tr><th>Sent At</th><td>{{ formatDate sent_at }}</td></tr>
    <tr><th>Assigned At</th><td>{{ formatDate assigned_at }}</td></tr>
    <tr><th>Concluded At</th><td>{{ formatDate concluded_at }}</td></tr>
    <tr><th>End Requested At</th><td>{{ formatDate end_requested_at }}</td></tr>
    <tr><th>End Requested Comments</th><td>{{ optionalValue end_requested_comments }}</td></tr>
    <tr><th>Cancellation Reason</th><td>{{ optionalString cancellation_reason }}</td></tr>
    <tr><th>Withdrawal Comments</th><td>{{ optionalString withdrawal_comments }}</td></tr>
    <tr><th>Draft Supplementary Risk Updated At</th><td>{{ formatDate draft_supplementary_risk_updated_at }}</td></tr>
    <tr><th>Relevant Sentence End Date</th><td>{{ formatDate relevant_sentence_end_date }}</td></tr>
  </table>

  <h3>Accessibility and Communication</h3>
  <table>
    <tr><th>Accessibility Needs</th><td>{{ optionalValue accessibility_needs }}</td></tr>
    <tr><th>Additional Needs Information</th><td>{{ optionalValue additional_needs_information }}</td></tr>
    <tr><th>When Unavailable</th><td>{{ optionalValue when_unavailable }}</td></tr>
    <tr><th>Needs Interpreter</th><td>{{ convertBoolean needs_interpreter }}</td></tr>
    <tr><th>Interpreting Language</th><td>{{ optionalString interpreting_language }}</td></tr>
    <tr><th>Has Additional Responsibilities</th><td>{{ convertBoolean has_additional_responsibilities }}</td></tr>
  </table>

  {{#contract}}
  <h3>Contract Details</h3>
  <table>
    <tr><th>NPS Region</th><td>{{ optionalString nps_region_id }}</td></tr>
    <tr><th>PCC Region</th><td>{{ optionalString pcc_region_id }}</td></tr>
    <tr><th>Referral Start Date</th><td>{{ formatDate referral_start_date }}</td></tr>
    <tr><th>Referral End Date</th><td>{{ formatDate referral_end_date }}</td></tr>
  </table>
  {{/contract}}

  {{#probation_practitioner_details}}
  <h3>Probation Practitioner Details</h3>
  <table>
    <tr><th>Name</th><td>{{ optionalString name }}</td></tr>
    <tr><th>PDU</th><td>{{ optionalString pdu }}</td></tr>
    <tr><th>Probation Office</th><td>{{ optionalString probation_office }}</td></tr>
    <tr><th>Role / Job Title</th><td>{{ optionalString role_job_title }}</td></tr>
    <tr><th>Establishment</th><td>{{ getPrisonName establishment }}</td></tr>
  </table>
  {{/probation_practitioner_details}}

  {{#referral_details}}
  <h3>Referral Details</h3>
  <table>
    <tr><th>Created At</th><td>{{ formatDate created_at }}</td></tr>
    <tr><th>Reason for Change</th><td>{{ optionalString reason_for_change }}</td></tr>
    <tr><th>Completion Deadline</th><td>{{ formatDate completion_deadline }}</td></tr>
    <tr><th>Further Information</th><td>{{ optionalString further_information }}</td></tr>
    <tr><th>Maximum Enforceable Days</th><td>{{ optionalValue maximum_enforceable_days }}</td></tr>
    <tr><th>Reason for Referral</th><td>{{ optionalString reason_for_referral }}</td></tr>
    <tr><th>Reason for Referral (Before Allocation)</th><td>{{ optionalString reason_for_referral_before_allocation }}</td></tr>
    <tr><th>Reason for Referral (Further Information)</th><td>{{ optionalString reason_for_referral_further_information }}</td></tr>
  </table>
  {{/referral_details}}

  {{#referal_location}}
  <h3>Referral Location</h3>
  <table>
    <tr><th>Referral ID</th><td>{{ optionalValue referal_id }}</td></tr>
    <tr><th>Type</th><td>{{ optionalString type }}</td></tr>
    <tr><th>Prison ID</th><td>{{ getPrisonName prison_id }}</td></tr>
    <tr><th>NOMIS Prison ID</th><td>{{ getPrisonName nomis_prison_id }}</td></tr>
    <tr><th>Referral Releasing Within 12 Weeks</th><td>{{ convertBoolean referral_releasing_12_weeks }}</td></tr>
    <tr><th>Expected Probation Office</th><td>{{ optionalString expected_probation_office }}</td></tr>
    <tr><th>Expected Probation Office Unknown Reason</th><td>{{ optionalString expected_probation_office_unknown_reason }}</td></tr>
  </table>
  {{/referal_location}}

  {{#end_of_service_report}}
  <h3>End of Service Report</h3>
  <table>
    <tr><th>Created At</th><td>{{ formatDate created_at }}</td></tr>
    <tr><th>Submitted At</th><td>{{ formatDate submitted_at }}</td></tr>
    <tr><th>Submitted By</th><td>{{ optionalString submitted_by }}</td></tr>
    <tr><th>Further Information</th><td>{{ optionalString further_information }}</td></tr>
    <tr><th>Referral ID</th><td>{{ optionalValue referral_id }}</td></tr>
  </table>

  {{#end_of_service_outcomes}}
  <h4>End of Service Outcome</h4>
  <table>
    <tr><th>Achievement Level</th><td>{{ optionalString acheivement_level }}</td></tr>
    <tr><th>Progression Comments</th><td>{{ optionalValue progression_comments }}</td></tr>
    <tr><th>Additional Task Comments</th><td>{{ optionalValue additional_task_comments }}</td></tr>
  </table>
  {{/end_of_service_outcomes}}
  {{/end_of_service_report}}

  {{#action_plans}}
  <h3>Action Plan</h3>
  <table>
    <tr><th>Created At</th><td>{{ formatDate created_at }}</td></tr>
    <tr><th>Number of Sessions</th><td>{{ optionalValue number_of_sessions }}</td></tr>
    <tr><th>Approved By</th><td>{{ optionalString approved_by }}</td></tr>
  </table>

  {{#action_plan_activities}}
  <h4>Activity</h4>
  <table>
    <tr><th>Description</th><td>{{ optionalString description }}</td></tr>
    <tr><th>Created At</th><td>{{ formatDate createdAt }}</td></tr>
  </table>
  {{/action_plan_activities}}
  {{/action_plans}}

  {{#appointment}}
  <h3>Appointment</h3>
  <table>
    <tr><th>ID</th><td>{{ optionalValue id }}</td></tr>
    <tr><th>Created At</th><td>{{ formatDate created_at }}</td></tr>
    <tr><th>Duration (minutes)</th><td>{{ optionalValue duration_minutes }}</td></tr>
    <tr><th>Attended</th><td>{{ optionalString attended }}</td></tr>
    <tr><th>Did Session Happen</th><td>{{ convertBoolean did_session_happen }}</td></tr>
    <tr><th>Late</th><td>{{ convertBoolean late }}</td></tr>
    <tr><th>Late Reason</th><td>{{ optionalValue late_reason }}</td></tr>
    <tr><th>Superseded</th><td>{{ convertBoolean superseded }}</td></tr>
    <tr><th>Superseded By Appointment ID</th><td>{{ optionalValue superseded_by_appointment_id }}</td></tr>
    <tr><th>Attendance Submitted At</th><td>{{ formatDate attendance_submitted_at }}</td></tr>
    <tr><th>Attendance Behaviour Submitted At</th><td>{{ formatDate attendance_behaviour_submitted_at }}</td></tr>
    <tr><th>Notify PP of Attendance Behaviour</th><td>{{ convertBoolean notifyppof_attendance_behaviour }}</td></tr>
    <tr><th>Appointment Feedback Submitted At</th><td>{{ formatDate appointment_feedback_submitted_at }}</td></tr>
    <tr><th>Session Feedback Submitted At</th><td>{{ formatDate session_feedback_submitted_at }}</td></tr>
    <tr><th>Session Feedback Submitted By</th><td>{{ optionalString session_feedback_submitted_by }}</td></tr>
    <tr><th>Session Summary</th><td>{{ optionalValue session_summary }}</td></tr>
    <tr><th>Session Response</th><td>{{ optionalValue session_response }}</td></tr>
    <tr><th>Session Concerns</th><td>{{ optionalValue session_concerns }}</td></tr>
    <tr><th>Session Behaviour</th><td>{{ optionalString session_behaviour }}</td></tr>
    <tr><th>Future Session Plan</th><td>{{ optionalValue future_session_plan }}</td></tr>
    <tr><th>Rescheduled Reasons</th><td>{{ optionalString rescheduled_reasons }}</td></tr>
    <tr><th>Additional Attendance Information</th><td>{{ optionalString additional_attendance_information }}</td></tr>
    <tr><th>Attendance Behaviour</th><td>{{ optionalString attendance_behaviour }}</td></tr>
    <tr><th>Attendance Failure Information</th><td>{{ optionalString attendance_failure_information }}</td></tr>
    <tr><th>No Attendance Information</th><td>{{ optionalString no_attendance_information }}</td></tr>
    <tr><th>No Session Reason Type</th><td>{{ optionalString no_session_reason_type }}</td></tr>
    <tr><th>No Session Reason (PoP Acceptable)</th><td>{{ optionalString no_session_reason_pop_acceptable }}</td></tr>
    <tr><th>No Session Reason (PoP Unacceptable)</th><td>{{ optionalString no_session_reason_pop_unacceptable }}</td></tr>
    <tr><th>No Session Reason (Logistics)</th><td>{{ optionalString no_session_reason_logistics }}</td></tr>
  </table>

  {{#appointment_delivery_type}}
  <h4>Appointment Delivery</h4>
  <table>
    <tr><th>Delivery Type</th><td>{{ optionalValue appointment_delivery_type }}</td></tr>
    <tr><th>NPS Office Code</th><td>{{ optionalString nps_office_code }}</td></tr>
    <tr><th>Session Type</th><td>{{ optionalString appointment_session_type }}</td></tr>
  </table>
  {{/appointment_delivery_type}}

  {{#appointment_delivery_address}}
  <h4>Appointment Delivery Address</h4>
  <table>
    <tr><th>First Address Line</th><td>{{ optionalValue first_address_line }}</td></tr>
    <tr><th>Second Address Line</th><td>{{ optionalString second_address_line }}</td></tr>
    <tr><th>Town or City</th><td>{{ optionalValue town_or_city }}</td></tr>
    <tr><th>Postcode</th><td>{{ optionalValue postcode }}</td></tr>
  </table>
  {{/appointment_delivery_address}}
  {{/appointment}}

  {{#case_notes}}
  <h3>Case Note</h3>
  <table>
    <tr><th>Subject</th><td>{{ optionalString subject }}</td></tr>
    <tr><th>Body</th><td>{{ optionalString body }}</td></tr>
    <tr><th>Sent At</th><td>{{ formatDate sent_at }}</td></tr>
  </table>
  {{/case_notes}}

</div>
{{/referral}}

{{#draft_referral}}
<div class="section">
  <h2>Draft Referral</h2>
  <table>
    <tr><th>Service User CRN</th><td>{{ optionalString service_user_crn }}</td></tr>
    <tr><th>Created At</th><td>{{ formatDate created_at }}</td></tr>
    <tr><th>Accessibility Needs</th><td>{{ optionalValue accessibility_needs }}</td></tr>
    <tr><th>Additional Needs Information</th><td>{{ optionalValue additional_needs_information }}</td></tr>
    <tr><th>When Unavailable</th><td>{{ optionalValue when_unavailable }}</td></tr>
    <tr><th>Needs Interpreter</th><td>{{ convertBoolean needs_interpreter }}</td></tr>
    <tr><th>Interpreting Language</th><td>{{ optionalString interpreting_language }}</td></tr>
    <tr><th>Has Additional Responsibilities</th><td>{{ convertBoolean has_additional_responsibilities }}</td></tr>
    <tr><th>Draft Supplementary Risk</th><td>{{ optionalString draft_supplementary_risk }}</td></tr>
    <tr><th>Draft Supplementary Risk Updated At</th><td>{{ formatDate draft_supplementary_risk_updated_at }}</td></tr>
    <tr><th>Person Current Location Type</th><td>{{ optionalString person_current_location_type }}</td></tr>
    <tr><th>Person Expected Release Date</th><td>{{ formatDate person_expected_release_date }}</td></tr>
    <tr><th>Person Expected Release Date Missing Reason</th><td>{{ optionalString person_expected_release_date_missing_reason }}</td></tr>
    <tr><th>Referral Releasing Within 12 Weeks</th><td>{{ convertBoolean referral_releasing_12_weeks }}</td></tr>
    <tr><th>Role / Job Title</th><td>{{ optionalString role_job_title }}</td></tr>
    <tr><th>Expected Probation Office</th><td>{{ optionalString expected_probation_office }}</td></tr>
    <tr><th>Expected Probation Office Unknown Reason</th><td>{{ optionalString expected_probation_office_unknown_reason }}</td></tr>
  </table>

  {{#contract}}
  <h3>Contract Details</h3>
  <table>
    <tr><th>NPS Region</th><td>{{ optionalString nps_region_id }}</td></tr>
    <tr><th>PCC Region</th><td>{{ optionalString pcc_region_id }}</td></tr>
    <tr><th>Referral Start Date</th><td>{{ formatDate referral_start_date }}</td></tr>
    <tr><th>Referral End Date</th><td>{{ formatDate referral_end_date }}</td></tr>
  </table>
  {{/contract}}

</div>
{{/draft_referral}}

{{^referral}}
{{^draft_referral}}
<div class="section">
  <p class="no-data">No subject access request data found for this CRN.</p>
</div>
{{/draft_referral}}
{{/referral}}

</body>
</html>
